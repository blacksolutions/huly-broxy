# Example bridge config for ansible deployment.
#
# Copy to `ansible/files/bridge.toml` and fill in real values. The real
# file is gitignored. For shared environments, prefer ansible-vault
# (see ../README.md "First-time setup") so the encrypted blob can be
# checked in.

[huly]
url = "https://huly.example.com"
workspace = "your-workspace"
accounts_url = "https://huly.example.com/_accounts"
use_binary_protocol = false
use_compression = true
reconnect_delay_ms = 1000
ping_interval_secs = 10

[huly.auth]
method = "password"
email = "user@example.com"
password = "REPLACE_ME"

# Or use token-based authentication:
# [huly.auth]
# method = "token"
# token = "your-jwt-here"

[nats]
# Internal NATS endpoint reachable from the deploy host.
url = "nats://127.0.0.1:4222"
subject_prefix = "huly"

[admin]
host = "0.0.0.0"
port = 9095
# Bearer token for /api/v1/* endpoints. Required.
# Must match mcp.bridge_api_token in the MCP config.
api_token = "change-me"

[log]
level = "info"
json = false
